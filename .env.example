# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy the relevant section to the matching app directory
#
#   Frontend:  cp .env.example frontend-app/.env   → fill in VITE_* vars
#   Backend:   cp .env.example backend-app/.env    → fill in TWILIO_* vars
#
# Never commit a real .env file. This file contains NO secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── frontend-app/.env ────────────────────────────────────────────────────────
# URL of the running backend. Remove or leave blank to use bundled mock data.
VITE_API_BASE_URL=http://localhost:8000


# ── backend-app/.env ─────────────────────────────────────────────────────────
# Twilio credentials — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The number alerts are SENT FROM (your Twilio number, e.g. +1XXXXXXXXXX)
TWILIO_FROM=+1XXXXXXXXXX

# The number alerts are SENT TO — always your OWN test number.
# Partner phones in partners.json are fabricated; never send to them.
TWILIO_TO=+1XXXXXXXXXX